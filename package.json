{
  "name": "quackhacks3",
  "version": "0.0.0",
  "private": true,
  "description": "Team Defenestrator - pose-matching survival game",
  "packageManager": "pnpm@8.10.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:client": "pnpm --filter @quackhacks/client dev",
    "dev:server": "pnpm --filter @quackhacks/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  }
}
