{
  "name": "@quackhacks/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./app": {
      "types": "./src/app.ts",
      "import": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "wrangler d1 migrations apply DB --local --config ../../wrangler.jsonc && wrangler dev --config ../../wrangler.jsonc --assets ../web/public --port 8787",
    "cf:dev": "wrangler dev --config ../../wrangler.jsonc --assets ../web/public --port 8787",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "cf:types": "wrangler types src/worker-configuration.d.ts --config ../../wrangler.jsonc",
    "start": "pnpm cf:dev"
  },
  "dependencies": {
    "@quackhacks/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
