{
  "name": "@quackhacks/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./app": {
      "types": "./src/app.ts",
      "import": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "pnpm db:push && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "start": "pnpm db:push && tsx src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "@libsql/client": "^0.17.3",
    "@quackhacks/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
